{
    "name": "gsebastiao/laravel-auditable",
    "description": "Auditoria Eloquent com resolução de labels legíveis (resolveMap), agrupamento de operações multi-tabela por batch, auditoria de falhas com debug e multitenancy opcional. Agnóstico à estratégia de tenancy.",
    "keywords": ["laravel", "audit", "auditing", "activity-log", "eloquent", "multitenancy", "saas", "audit-trail"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Gabriel Sebastião",
            "email": "voce@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Gsebastiao\\Auditable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gsebastiao\\Auditable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gsebastiao\\Auditable\\AuditableServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
